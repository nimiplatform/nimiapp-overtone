{
  "intentVersion": 1,
  "scaffoldVersion": "2026-05-29.app-source-snapshot",
  "initRequired": true,
  "initCommand": "pnpm exec nimi-app init",
  "initOrder": [
    "nimi-app create",
    "pnpm install",
    "pnpm exec nimi-app init"
  ],
  "profile": "standalone",
  "appId": "nimi.overtone",
  "appTitle": "Nimi Overtone",
  "packageName": "nimiapp-overtone",
  "packageAuthor": null,
  "cargoPackageName": "nimiapp-overtone-shell",
  "tauriIdentifier": "ai.nimi.apps.nimi.overtone",
  "accentPack": "nimi-accent",
  "permissionDeclarations": [
    {
      "scope": "ai.spend.meter",
      "purpose": "Meter Runtime AI execution for text assistance and music generation."
    },
    {
      "scope": "ai_profile.selection.consume",
      "purpose": "Consume Runtime route and model profile selections for Overtone generation."
    },
    {
      "scope": "data.scope.write",
      "purpose": "Publish finalized Overtone takes and metadata through Realm."
    },
    {
      "scope": "file.read.scoped",
      "qualifier": "app-local-drafts",
      "purpose": "Read drafts owned by this app during author testing."
    },
    {
      "scope": "file.write.scoped",
      "qualifier": "app-local-drafts",
      "purpose": "Store drafts owned by this app during author testing."
    }
  ],
  "scaffoldOmissions": [
    "dev-preview.html",
    "src-tauri/src/tester_storage.rs",
    "src-tauri/src/world_tour.rs",
    "src/dev-preview.tsx",
    "src/shell/ai/**",
    "src/shell/routes/settings.tsx",
    "src/shell/routes/settings/**",
    "src/tester/**",
    "test/settings-surface-read.mjs",
    "test/tester-*",
    "test/tsc-build.mjs",
    "test/world-tour-contract.test.mjs"
  ],
  "devPort": 1507,
  "dependencyMatrix": {
    "npm": {
      "@nimiplatform/app-tools": "^0.1.4",
      "@nimiplatform/nimi-coding": "0.2.5",
      "@nimiplatform/sdk": "^0.6.0",
      "@nimiplatform/kit": "^0.2.0",
      "@tauri-apps/api": "^2.9.1",
      "i18next": "^25.8.18",
      "lucide-react": "^0.577.0",
      "react": "^19.1.0",
      "react-dom": "^19.1.0",
      "react-i18next": "^16.5.8",
      "typescript": "^5.9.3",
      "vite": "^7.2.4",
      "tailwindcss": "^4.3.0",
      "@tauri-apps/cli": "^2.11.2",
      "@tailwindcss/vite": "^4.3.0",
      "@types/three": "^0.184.1",
      "@vitejs/plugin-react": "^5.1.1",
      "yaml": "^2.9.0"
    },
    "cargo": {
      "nimi-shell-tauri": "0.1.0",
      "tauri": "2",
      "tauri-build": "2"
    },
    "toolchain": {
      "node": ">=20",
      "pnpm": ">=9",
      "rust": ">=1.80",
      "tauri": "2"
    }
  },
  "semantics": {
    "role": "app-scaffold-init-input",
    "authority": "app-tools-orchestration-input-not-platform-admission",
    "nimicodingProjectionOwner": "@nimiplatform/nimi-coding"
  }
}
